    {
      "name": "Webhooks",
      "item": [
        {
          "name": "POST inbound bank confirmation",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Webhook-Signature",
                "value": ""
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotency_key\": \"{{webhook_idempotency_key}}\",\n  \"application_id\": \"{{application_id}}\",\n  \"event\": \"bank_confirmation\"\n}"
            },
            "url": {
              "raw": "{{api_base_url}}/webhooks/bank",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "webhooks",
                "bank"
              ]
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('webhook_idempotency_key', `postman-bank-${Date.now()}`);",
                  "const rawBody = pm.variables.replaceIn(pm.request.body.raw);",
                  "const secret = pm.environment.get('webhook_secret');",
                  "const signature = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Signature', value: signature });"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('webhook accepted', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST inbound bank confirmation replay",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Webhook-Signature",
                "value": ""
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotency_key\": \"{{webhook_idempotency_key}}\",\n  \"application_id\": \"{{application_id}}\",\n  \"event\": \"bank_confirmation\"\n}"
            },
            "url": {
              "raw": "{{api_base_url}}/webhooks/bank",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "webhooks",
                "bank"
              ]
            },
            "description": "Run immediately after the valid inbound bank confirmation. It uses the same idempotency key and should return 200 without applying the mutation twice."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const rawBody = pm.variables.replaceIn(pm.request.body.raw);",
                  "const secret = pm.environment.get('webhook_secret');",
                  "const signature = CryptoJS.HmacSHA256(rawBody, secret).toString(CryptoJS.enc.Hex);",
                  "pm.request.headers.upsert({ key: 'X-Webhook-Signature', value: signature });"
                ]
              }
            }
          ]
        },
        {
          "name": "POST inbound webhook invalid signature",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Webhook-Signature",
                "value": "wrong-signature"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idempotency_key\": \"postman-invalid-signature\",\n  \"application_id\": \"{{application_id}}\",\n  \"event\": \"bank_confirmation\"\n}"
            },
            "url": {
              "raw": "{{api_base_url}}/webhooks/bank",
              "host": [
                "{{api_base_url}}"
              ],
              "path": [
                "webhooks",
                "bank"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('invalid signature is rejected', function () { pm.response.to.have.status(401); });"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
