# Copy to `.env` to override the development defaults baked into docker-compose.yml.
# These are NON-SECRET local defaults; never commit real credentials.

# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5

# PostgreSQL (the api connects to the `postgres` compose service)
DATABASE_USER=bravo
DATABASE_PASSWORD=bravo
DATABASE_NAME=bravo_development
TEST_DATABASE_NAME=bravo_test
# DATABASE_HOST / DATABASE_PORT default to postgres:5432 inside compose.

# Redis (ActionCable / Sidekiq, wired in later milestones)
REDIS_URL=redis://redis:6379/0
