# Copy to `.env` to override the development defaults baked into docker-compose.yml.
# These are NON-SECRET local defaults; never commit real credentials.

# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5

# PostgreSQL (the api connects to the `postgres` compose service)
DATABASE_USER=bravo
DATABASE_PASSWORD=bravo
DATABASE_NAME=bravo_development
TEST_DATABASE_NAME=bravo_test
# DATABASE_HOST / DATABASE_PORT default to postgres:5432 inside compose.

# Redis (ActionCable / Sidekiq, wired in later milestones)
REDIS_URL=redis://redis:6379/0

# Active Record encryption + blind index keys.
# DEV PLACEHOLDERS — generate real keys for production via the secrets manager
# (e.g. `bin/rails db:encryption:init`). Never commit real keys.
AR_ENCRYPTION_PRIMARY_KEY=dev_only_primary_key_replace_in_production_0001
AR_ENCRYPTION_DETERMINISTIC_KEY=dev_only_deterministic_key_replace_in_prod_0002
AR_ENCRYPTION_KEY_DERIVATION_SALT=dev_only_key_derivation_salt_replace_in_prod_0003
BLIND_INDEX_KEY=dev_only_blind_index_key_replace_in_production_0004

# JWT signing secret. Optional in development (falls back to secret_key_base);
# REQUIRED and rotated via the secrets manager in production.
# JWT_SECRET=replace_me_in_production
